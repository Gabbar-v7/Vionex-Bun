{
  "name": "vionex-bun",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "web:dev": "bun run --cwd apps/web web:dev",
    "web:build": "bun run --cwd apps/web web:build",
    "web:start": "bun run --cwd apps/web web:start",
    "web:lint": "bun run --cwd apps/web web:lint",
    "storybook:dev": "bun run --cwd apps/web storybook:dev",
    "storybook:build": "bun run --cwd apps/web storybook:build",
    "api:dev": "bun run --cwd apps/api api:dev",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "format:check": "oxfmt --check",
    "format": "oxfmt",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
